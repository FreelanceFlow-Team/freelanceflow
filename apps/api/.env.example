DATABASE_URL="postgresql://postgres:postgres@localhost:5432/freelanceflow_dev"
JWT_SECRET="change-me-in-production-use-a-long-random-string"
PORT=3010
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# Email configuration (optional, for invoice PDF delivery)
# For development without SMTP, leave SMTP_HOST empty to use test mode
EMAIL_FROM="noreply@freelanceflow.app"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""

# Upstash Redis cache (optional — cache disabled if not set)
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
